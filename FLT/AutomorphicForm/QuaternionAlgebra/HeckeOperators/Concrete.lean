  set Q╬▓ := v.adicCompletionIntegers F ÔžŞ Ideal.span ({╬▓} : Set _) with hQ╬▓
  rw [show (ÔłĹßÂá (i : Q╬▒) (j : Q╬▓),
      unipotent_mul_diag r ╬▒ h╬▒ i ÔÇó unipotent_mul_diag r ╬▓ h╬▓ j ÔÇó a.1) =
    ÔłĹßÂá (p : Q╬▒ ├Ś Q╬▓),
      unipotent_mul_diag r ╬▒ h╬▒ p.1 ÔÇó unipotent_mul_diag r ╬▓ h╬▓ p.2 ÔÇó a.1 from
    (finsum_curry (╬▒ := Q╬▒) (╬▓ := Q╬▓)
      (fun p => unipotent_mul_diag r ╬▒ h╬▒ p.1 ÔÇó unipotent_mul_diag r ╬▓ h╬▓ p.2 ÔÇó a.1)
      (Set.toFinite _)).symm]
  rw [ÔćÉ finsum_comp_equiv (Ideal.Quotient.prodEquivSpanMul (╬▓ := ╬▓) h╬▒)
    (f := fun (k : v.adicCompletionIntegers F ÔžŞ Ideal.span {╬▒ * ╬▓}) =>
      unipotent_mul_diag r (╬▒ * ╬▓) (h╬▒.mul h╬▓) k ÔÇó a.1)]
  refine finsum_congr (fun p => ?_)
  obtain ÔčĘi, jÔčę := p
  -- LHS: `(unipotent_mul_diag ╬▒ i * unipotent_mul_diag ╬▓ j) ÔÇó a.1
  --      = unipotent_mul_diag_lift (╬▒*╬▓) (╬▒ * j.out + i.out) ÔÇó a.1`.
