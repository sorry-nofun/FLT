namespace HeckeOperator

set_option maxSynthPendingDepth 1 in
open scoped TensorProduct.RightActions in
omit [IsTotallyReal F] [IsQuaternionAlgebra F D] in
/-- The two diagonal group elements `diag(¤ľ_v, 1)` and `diag(¤ľ_w, 1)` (pulled back through
the rigidification `r`) commute unconditionally: diagonal matrices over a commutative ring
always commute. This is the group-theoretic fact underlying the commutativity of the
Hecke operators `T_v` and `T_w`; note however that commutation of the group elements
alone is *not* sufficient to deduce commutation of the associated Hecke operators ÔÇö
that still requires a description of the double coset `U1 ┬Ě diag(¤ľ_v,1) ┬Ě U1` as a union
of single cosets (see `AbstractHeckeOperator.comm`). -/
lemma T_diag_commute (v w : HeightOneSpectrum (­Łô× F)) :
    Commute
      (Units.map r.symm.toMonoidHom (Matrix.GeneralLinearGroup.diagonal
        ![FiniteAdeleRing.localUniformiserUnit F v, 1]))
      (Units.map r.symm.toMonoidHom (Matrix.GeneralLinearGroup.diagonal
        ![FiniteAdeleRing.localUniformiserUnit F w, 1])) := by
  refine Commute.map ?_ (Units.map r.symm.toMonoidHom)
  -- Two diagonal matrices over a commutative ring commute.
  ext i j
  fin_cases i <;> fin_cases j <;>
    simp [Matrix.GeneralLinearGroup.diagonal, Matrix.diagonal, Fin.isValue,
          Matrix.cons_val_fin_one, Matrix.cons_val_zero, Matrix.cons_val_one,
          Matrix.mul_apply, mul_comm]

end HeckeOperator

set_option maxHeartbeats 1000000 in
-- Elaborating this instance exceeds the default heartbeat budget: the 4-way
-- case split under `Algebra.adjoinCommRingOfComm` triggers `whnf` on
-- `FiniteAdeleRing.GL2.restrictedProduct`, which is expensive to unfold.
noncomputable instance instCommRing :
    CommRing (HeckeAlgebra F D r S R) := by
  -- #585: reduce commutativity of the Hecke algebra to pairwise commutativity of the
  -- generators `TßÁą` (for `v Ôłë S`) and `UßÁą,╬▒` (for `v Ôłł S`, `╬▒ Ôëá 0`).
  unfold HeckeAlgebra
  apply Algebra.adjoinCommRingOfComm R
  rintro a ha b hb
  -- Case split on `ha`, `hb` to handle the four generator pairs:
  --   (T_v, T_w), (T_v, U_{w,╬▓}), (U_{v,╬▒}, T_w), (U_{v,╬▒}, U_{w,╬▓}).
  rcases ha with ÔčĘv, hv, rflÔčę | ÔčĘv, hv, ╬▒, h╬▒, rflÔčę <;>
  rcases hb with ÔčĘw, hw, rflÔčę | ÔčĘw, hw, ╬▓, h╬▓, rflÔčę
  ┬Ě -- (T_v, T_w): Hecke operators at good primes commute. Follows from the fact that
    -- the coset representatives `diag(¤ľ_v,1)` and `diag(¤ľ_w,1)` have disjoint support
    -- in the restricted product when v Ôëá w (and trivially when v = w).
    by_cases hvw : v = w
    ┬Ě -- v = w: T_v = T_w, so the product commutes with itself trivially.
      subst hvw
      rfl
    ┬Ě -- v Ôëá w: disjoint support argument via `AbstractHeckeOperator.comm`.
      -- TODO: Blocked on missing infrastructure. `AbstractHeckeOperator.comm` requires a
      -- `Set.BijOn QuotientGroup.mk s (QuotientGroup.mk '' (U1 * {diag(¤ľ_v,1)}))` witness
      -- exhibiting a concrete set `s` of v-supported left-coset representatives for the
      -- double coset `U1 ┬Ě diag(¤ľ_v,1) ┬Ě U1`. The only such witness currently in the
      -- codebase is `bijOn_unipotent_mul_diagU1_U1diagU1`, which is proven only for
      -- `v Ôłł S` (where U1 at v is the Iwahori-style subgroup and the double coset has
      -- |O_v / ╬▒| single cosets). For `v Ôłë S`, U1 at v is the full maximal compact
      -- `GLÔéé(­Łĺ¬_v)` and the classical `T_v` double coset decomposes into q+1 single
      -- cosets (`diag(¤ľ_v,1)` and `(1 t; 0 ¤ľ_v)` for `t` in ­Łĺ¬_v/¤ľ_v), but no analogue of
      -- `bijOn_unipotent_mul_diagU1_U1diagU1` has been built for this case. Closing this
      -- sorry requires adding (a) a local lemma in Local.lean giving a BijOn for the
      -- T_v double coset at a good prime, and (b) the global lift mirroring
      -- `bijOn_unipotent_mul_diagU1_U1diagU1` in this file.
      sorry
  ┬Ě -- (T_v, U_{w,╬▓}): good prime T_v commutes with bad prime U_{w,╬▓}. Since v Ôłë S and
    -- w Ôłł S, we have v Ôëá w, so the representatives are supported at disjoint places.
    -- TODO: Blocked on the same missing T_v coset-representative infrastructure as the
    -- (T_v, T_w) case above. The U_{w,╬▓} side has
    -- `bijOn_unipotent_mul_diagU1_U1diagU1 r S ╬▓ h╬▓ hw` available, but the T_v side
    -- still needs a BijOn witness for `U1 ┬Ě diag(¤ľ_v,1) ┬Ě U1` before
    -- `AbstractHeckeOperator.comm` can be applied.
    sorry
  ┬Ě -- (U_{v,╬▒}, T_w): symmetric to the previous case.
    -- TODO: Blocked on the same missing T_w coset-representative infrastructure.
    sorry
  ┬Ě -- (U_{v,╬▒}, U_{w,╬▓}): bad prime operators.
    by_cases hvw : v = w
    ┬Ě -- v = w: use `HeckeOperator.U_comm`. Need to transport `h╬▓` across `hvw`.
      subst hvw
      change HeckeOperator.U r S R ╬▒ h╬▒ * HeckeOperator.U r S R ╬▓ h╬▓ =
        HeckeOperator.U r S R ╬▓ h╬▓ * HeckeOperator.U r S R ╬▒ h╬▒
      exact HeckeOperator.U_comm r S R hv h╬▒ h╬▓
    ┬Ě -- v Ôëá w: disjoint support argument via `AbstractHeckeOperator.comm`.
      change HeckeOperator.U r S R ╬▒ h╬▒ * HeckeOperator.U r S R ╬▓ h╬▓ =
        HeckeOperator.U r S R ╬▓ h╬▓ * HeckeOperator.U r S R ╬▒ h╬▒
      unfold HeckeOperator.U
      apply AbstractHeckeOperator.comm (R := R)
      refine ÔčĘunipotent_mul_diag_image r ╬▒ h╬▒, unipotent_mul_diag_image r ╬▓ h╬▓,
        bijOn_unipotent_mul_diagU1_U1diagU1 r S ╬▒ h╬▒ hv,
        bijOn_unipotent_mul_diagU1_U1diagU1 r S ╬▓ h╬▓ hw, ?_Ôčę
      rintro a ÔčĘi, _, rflÔčę b ÔčĘj, _, rflÔčę
      -- `unipotent_mul_diag r ╬▒ h╬▒ i` is supported at `v` and
      -- `unipotent_mul_diag r ╬▓ h╬▓ j` is supported at `w`, with `v Ôëá w`, so they commute.
      exact (HeckeOperator.unipotent_mul_diag_commute_of_ne r hvw h╬▒ h╬▓ i j).eq

variable {F S} in
/-- The Hecke operator TßÁą as an element of the Hecke algebra. -/
