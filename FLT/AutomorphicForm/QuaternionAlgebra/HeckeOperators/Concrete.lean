        Units.mapEquiv r.symm.toMulEquiv _
      congr 1
      rw [ÔćÉ map_inv, ÔćÉ map_mul, ÔćÉ RestrictedProduct.mulSingle_inv,
        ÔćÉ RestrictedProduct.mulSingle_mul]
      congr 1
      rw [Local.GL2.unipotent_mul_diag_inv_mul_unipotent_mul_diag ╬│ h╬│ tÔéé tÔéü]
      congr 1
      -- Need: `(╬│ : adicCompletion F v)Ôü╗┬╣ * (tÔéü + -tÔéé) = m` (in `adicCompletion F v`).
      have hmval : ((tÔéü : adicCompletion F v) + -(tÔéé : adicCompletion F v)) =
          ((╬│ : adicCompletion F v)) * (m : adicCompletion F v) := by
        have hh : ((m : adicCompletion F v)) * (╬│ : adicCompletion F v) =
            (tÔéü : adicCompletion F v) - (tÔéé : adicCompletion F v) := by
