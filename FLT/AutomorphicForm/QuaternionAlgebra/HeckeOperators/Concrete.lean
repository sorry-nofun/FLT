          exact Local.GL2.unipotent_mem_U1 (v := w) m
        ┬Ě rw [FiniteAdeleRing.GL2.toAdicCompletion_restrictedProduct_symm_mulSingle_ne hwv _]
          exact (GL2.localTameLevel w).one_mem
    ┬Ě -- Applying `Units.map r.symm.toMonoidHom` to the witness yields `u''`.
      change Units.map r.symm.toMonoidHom _ = u''
      rw [hu''_def, unipotent_mul_diag_lift, unipotent_mul_diag_lift]
      change _ = (Units.mapEquiv r.symm.toMulEquiv _)Ôü╗┬╣ *
        (Units.mapEquiv r.symm.toMulEquiv _)
      rw [ÔćÉ map_inv, ÔćÉ map_mul]
