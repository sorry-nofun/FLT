open scoped TensorProduct

-- Oops! This is also `IsDedekindDomain.HeightOneSpectrum.QuaternionAlgebra.TameLevel`
-- in `FLT.QuaternionAlgebra.NumberField`, defined differently (using `Subgroup.comap` not `map`).
-- Don't care which one survives.
variable {F D} in
open scoped TensorProduct.RightActions in
/-- U1(S) -/
noncomputable abbrev U1 : Subgroup (D ÔŐŚ[F] (IsDedekindDomain.FiniteAdeleRing (­Łô× F) F))╦ú :=
  Subgroup.map (Units.map r.symm.toMonoidHom) (GL2.TameLevel S)

omit [IsTotallyReal F] in
variable {F D} in
open scoped TensorProduct.RightActions in
lemma U1_compact :
    IsCompact (U1 r S :
      Set (D ÔŐŚ[F] (IsDedekindDomain.FiniteAdeleRing (­Łô× F) F))╦ú) := by
  rw [U1, Subgroup.coe_map]
  have hc : Continuous r.symm :=
    IsDedekindDomain.HeightOneSpectrum.Rigidification.continuous_invFun D r
  exact (GL2.TameLevel.isCompact S).image
    (Continuous.units_map r.symm.toMonoidHom hc)

omit [IsTotallyReal F] in
variable {F D} in
open scoped TensorProduct.RightActions in
lemma U1_open :
    IsOpen (U1 r S :
      Set (D ÔŐŚ[F] (IsDedekindDomain.FiniteAdeleRing (­Łô× F) F))╦ú) := by
  rw [U1, Subgroup.coe_map]
  have hcr : Continuous r :=
    IsDedekindDomain.HeightOneSpectrum.Rigidification.continuous_toFun D r
  rw [Set.image_eq_preimage_of_inverse
    (f := Units.map r.symm.toMonoidHom)
    (g := Units.map r.toMonoidHom)
    (fun x => by ext; simp) (fun x => by ext; simp)]
  exact (GL2.TameLevel.isOpen S).preimage
    (Continuous.units_map r.toMonoidHom hcr)

variable (R : Type*) [CommRing R]

namespace HeckeOperator

variable {F D S} in
set_option maxSynthPendingDepth 1 in
open scoped TensorProduct.RightActions in
/-- The Hecke operator T_v as an R-linear map from R-valued quaternionic weight 2
automorphic forms of level U_1(S).
-/
noncomputable def T (v : HeightOneSpectrum (­Łô× F)) :
    WeightTwoAutomorphicFormOfLevel (U1 r S) R ÔćĺÔéŚ[R]
    WeightTwoAutomorphicFormOfLevel (U1 r S) R :=
  letI : DecidableEq (HeightOneSpectrum (­Łô× F)) := Classical.typeDecidableEq _
  let g : (D ÔŐŚ[F] (IsDedekindDomain.FiniteAdeleRing (­Łô× F) F))╦ú :=
    Units.map r.symm.toMonoidHom (Matrix.GeneralLinearGroup.diagonal
    ![FiniteAdeleRing.localUniformiserUnit F v, 1])
  AbstractHeckeOperator.HeckeOperator (R := R) g (U1 r S) (U1 r S)
  (QuotientGroup.mk_image_finite_of_compact_of_open (U1_compact r S) (U1_open r S))

section U

variable {F D}

variable {v : HeightOneSpectrum (­Łô× F)} (╬▒ : v.adicCompletionIntegers F) (h╬▒ : ╬▒ Ôëá 0)

open scoped TensorProduct.RightActions
open scoped Pointwise

noncomputable instance : DecidableEq (HeightOneSpectrum (­Łô× F)) := Classical.typeDecidableEq _

/-- The (global) matrix element `diag[╬▒, 1]`. -/
noncomputable abbrev diag :
    (D ÔŐŚ[F] (FiniteAdeleRing (­Łô× F) F))╦ú :=
  Units.mapEquiv r.symm.toMulEquiv
    (FiniteAdeleRing.GL2.restrictedProduct.symm
    (RestrictedProduct.mulSingle _ _ (Local.GL2.diag ╬▒ h╬▒)))

/-- The (global) matrix element `(unipotent t) * (diag ╬▒ h╬▒) = !![╬▒, t; 0, 1]`.
Here `t Ôłł ­Łĺ¬ßÁą / ╬▒` and we lift it arbitrarily to `­Łĺ¬ßÁą`. -/
noncomputable def unipotent_mul_diag (t : ÔćĹ(adicCompletionIntegers F v) ÔžŞ (Ideal.span {╬▒})) :
    (D ÔŐŚ[F] (FiniteAdeleRing (­Łô× F) F))╦ú :=
  Units.mapEquiv r.symm.toMulEquiv
    (FiniteAdeleRing.GL2.restrictedProduct.symm
    (RestrictedProduct.mulSingle _ _
      (Local.GL2.unipotent_mul_diag ╬▒ h╬▒ (Quotient.out t : adicCompletionIntegers F v))))

/-- The set of elements `unipotent_mul_diag`, that is, the elements of `(D ÔŐŚ ­ŁöŞ_F^Ôł×)╦ú`
which are `(╬▒ t;0 1)` at `v` and the identity elsewhere, as `t` runs through a set
of coset reps of `­Łô×ßÁą / ╬▒`. These will form a set of coset representatives for `U1 diag U1`.
-/
noncomputable def unipotent_mul_diag_image :
    Set (D ÔŐŚ[F] (FiniteAdeleRing (­Łô× F) F))╦ú :=
  (unipotent_mul_diag r ╬▒ h╬▒) '' ÔŐĄ

omit [IsTotallyReal F] [IsQuaternionAlgebra F D] in
lemma unipotent_mul_diag_inj :
    Set.InjOn (unipotent_mul_diag r ╬▒ h╬▒) ÔŐĄ := by
  intro tÔéü hÔéü tÔéé hÔéé h
  simp only [unipotent_mul_diag, EmbeddingLike.apply_eq_iff_eq, RestrictedProduct.ext_iff] at h
  let h' := h v; simp only [RestrictedProduct.mulSingle_eq_same, Units.ext_iff] at h'
  rw [ÔćÉ Matrix.ext_iff] at h'
  let h'' := h' 0 1
  simpa [Local.GL2.unipotent_mul_diag, Matrix.GeneralLinearGroup.GL2.unipotent, Local.GL2.diag,
    Matrix.unitOfDetInvertible, Matrix.GeneralLinearGroup.diagonal] using h''

/-- The double coset space `UÔéü(S) diag(╬▒ßÁą,1) UÔéü(S)` as a set of left cosets. -/
noncomputable def U1diagU1 :
    Set ((D ÔŐŚ[F] (FiniteAdeleRing (­Łô× F) F))╦ú ÔžŞ (U1 r S)) :=
  QuotientGroup.mk '' ((U1 r S) * {diag r ╬▒ h╬▒})

set_option maxHeartbeats 800000 in
-- Increased heartbeat due to significant `rfl`/definitional unfolding through the
-- restricted-product + rigidification pipeline in the InjOn and SurjOn branches.
omit [IsTotallyReal F] [IsQuaternionAlgebra F D] in
theorem bijOn_unipotent_mul_diagU1_U1diagU1 (hv : v Ôłł S) :
    (unipotent_mul_diag_image r ╬▒ h╬▒).BijOn QuotientGroup.mk (U1diagU1 r S ╬▒ h╬▒) := by
  refine ÔčĘ?_, ?_, ?_Ôčę
  ┬Ě -- MapsTo: each `unipotent_mul_diag r ╬▒ h╬▒ i` can be written as `u_glob * diag r ╬▒ h╬▒`
    -- for some `u_glob Ôłł U1 r S`, where `u_glob` is the image of a v-supported unipotent
    -- matrix `!![1, (out i); 0, 1]` through the restricted product + rigidification.
    rintro _ ÔčĘi, _, rflÔčę
    -- Define the v-supported global unipotent element.
    set u_glob : (D ÔŐŚ[F] (FiniteAdeleRing (­Łô× F) F))╦ú :=
      Units.mapEquiv r.symm.toMulEquiv
        (FiniteAdeleRing.GL2.restrictedProduct.symm
          (RestrictedProduct.mulSingle _ v
            (Matrix.GeneralLinearGroup.GL2.unipotent
              ((Quotient.out i : adicCompletionIntegers F v) :
                adicCompletion F v)))) with hu_glob_def
    -- Show `u_glob Ôłł U1 r S`.
    have hu_glob_mem : u_glob Ôłł U1 r S := by
      refine Subgroup.mem_map.mpr ÔčĘ_, ?_, rflÔčę
      refine ÔčĘfun w => ?_, fun w _ => ?_Ôčę
      ┬Ě by_cases hwv : w = v
        ┬Ě subst hwv
          rw [FiniteAdeleRing.GL2.toAdicCompletion_restrictedProduct_symm_mulSingle_same w _]
          exact (Local.GL2.unipotent_mem_U1 (v := w) (Quotient.out i)).1
        ┬Ě rw [FiniteAdeleRing.GL2.toAdicCompletion_restrictedProduct_symm_mulSingle_ne hwv _]
          exact (GL2.localFullLevel w).one_mem
      ┬Ě by_cases hwv : w = v
        ┬Ě subst hwv
          rw [FiniteAdeleRing.GL2.toAdicCompletion_restrictedProduct_symm_mulSingle_same w _]
          exact Local.GL2.unipotent_mem_U1 (v := w) (Quotient.out i)
        ┬Ě rw [FiniteAdeleRing.GL2.toAdicCompletion_restrictedProduct_symm_mulSingle_ne hwv _]
          exact (GL2.localTameLevel w).one_mem
    -- Show `unipotent_mul_diag r ╬▒ h╬▒ i = u_glob * diag r ╬▒ h╬▒`.
    have h_eq : unipotent_mul_diag r ╬▒ h╬▒ i = u_glob * diag r ╬▒ h╬▒ := by
      rw [hu_glob_def]
      unfold unipotent_mul_diag diag
      rw [ÔćÉ map_mul, ÔćÉ map_mul, ÔćÉ RestrictedProduct.mulSingle_mul]
      rfl
    refine ÔčĘu_glob * diag r ╬▒ h╬▒, Set.mul_mem_mul hu_glob_mem rfl, ?_Ôčę
    rw [ÔćÉ h_eq]
  ┬Ě -- InjOn: if `mk (unipotent_mul_diag i) = mk (unipotent_mul_diag j)`, then the ratio
    -- is in `U1 r S`, and its projection at `v` is a unipotent `!![1, (j - i)/╬▒; 0, 1]`.
    -- For this to be in `localFullLevel v` we need `(j - i)/╬▒ Ôłł O_v`, i.e. `╬▒ | (j - i)`,
    -- i.e. `i = j` in `O_v / ╬▒`.
    rintro _ ÔčĘi, _, rflÔčę _ ÔčĘj, _, rflÔčę h
    refine congrArg (unipotent_mul_diag r ╬▒ h╬▒) ?_
    have hratio : (unipotent_mul_diag r ╬▒ h╬▒ i)Ôü╗┬╣ * (unipotent_mul_diag r ╬▒ h╬▒ j) Ôłł U1 r S :=
      QuotientGroup.eq.mp h
    set t_i : adicCompletionIntegers F v := Quotient.out i
    set t_j : adicCompletionIntegers F v := Quotient.out j
    -- Directly build a witness `w' Ôłł GL2.TameLevel S`, then derive that its image at `v`
    -- (which is `(Local.unipotent_mul_diag t_i)Ôü╗┬╣ * Local.unipotent_mul_diag t_j
    --  = Local.unipotent (╬▒Ôü╗┬╣ * (t_j - t_i))`) lies in `localFullLevel v`.
    set g_loc : GL (Fin 2) (adicCompletion F v) :=
      (Local.GL2.unipotent_mul_diag ╬▒ h╬▒ t_i)Ôü╗┬╣ *
        Local.GL2.unipotent_mul_diag ╬▒ h╬▒ t_j with hg_loc_def
    set w' : GL (Fin 2) (FiniteAdeleRing (­Łô× F) F) :=
      FiniteAdeleRing.GL2.restrictedProduct.symm
        (RestrictedProduct.mulSingle _ v g_loc) with hw'_def
    -- The image of `w'` under `Units.mapEquiv r.symm.toMulEquiv` is the ratio.
    have h_image : Units.mapEquiv r.symm.toMulEquiv w' =
        (unipotent_mul_diag r ╬▒ h╬▒ i)Ôü╗┬╣ * (unipotent_mul_diag r ╬▒ h╬▒ j) := by
      change Units.mapEquiv r.symm.toMulEquiv
          (FiniteAdeleRing.GL2.restrictedProduct.symm
            (RestrictedProduct.mulSingle _ v g_loc)) =
        (unipotent_mul_diag r ╬▒ h╬▒ i)Ôü╗┬╣ * (unipotent_mul_diag r ╬▒ h╬▒ j)
      unfold unipotent_mul_diag
      rw [ÔćÉ map_inv, ÔćÉ map_mul, ÔćÉ map_inv, ÔćÉ map_mul, ÔćÉ RestrictedProduct.mulSingle_inv,
        ÔćÉ RestrictedProduct.mulSingle_mul]
    -- Extract the preimage from membership in U1.
    obtain ÔčĘw, hw_mem, hw_eqÔčę := Subgroup.mem_map.mp hratio
    -- Since `Units.mapEquiv r.symm.toMulEquiv` is injective and both `w` and `w'` map to
    -- the ratio, we have `w = w'`.
    have hw'_eq : w' = w := by
      apply (Units.mapEquiv r.symm.toMulEquiv).injective
      rw [h_image]; exact hw_eq.symm
    have hw'_mem : w' Ôłł GL2.TameLevel S := hw'_eq ÔľŞ hw_mem
    -- The projection of `w'` at `v` is `g_loc`, hence `g_loc Ôłł localFullLevel v`.
    have hg_loc_mem : g_loc Ôłł GL2.localFullLevel v := by
      have := hw'_mem.1 v
      rwa [hw'_def,
        FiniteAdeleRing.GL2.toAdicCompletion_restrictedProduct_symm_mulSingle_same v g_loc] at this
    -- Entry (0,1) of `g_loc`, which equals `╬▒Ôü╗┬╣ * (t_j - t_i)`, must be in `O_v`.
    have h01_int : ((g_loc : GL (Fin 2) (adicCompletion F v)) 0 1) Ôłł
        (adicCompletionIntegers F v) := GL2.v_le_one_of_mem_localFullLevel _ hg_loc_mem 0 1
    have hg_loc_val : g_loc = Matrix.GeneralLinearGroup.GL2.unipotent
        ((╬▒ : v.adicCompletion F)Ôü╗┬╣ *
          ((t_j : adicCompletion F v) + -(t_i : adicCompletion F v))) := by
      exact Local.GL2.unipotent_mul_diag_inv_mul_unipotent_mul_diag ╬▒ h╬▒ t_i t_j
    have h01_eq : ((g_loc : GL (Fin 2) (adicCompletion F v)) 0 1) =
        (╬▒ : v.adicCompletion F)Ôü╗┬╣ *
          ((t_j : adicCompletion F v) + -(t_i : adicCompletion F v)) := by
      rw [hg_loc_val]
      simp [Matrix.GeneralLinearGroup.GL2.unipotent, Matrix.unitOfDetInvertible]
    rw [h01_eq] at h01_int
    -- Conclude `i = j` in `O_v / ╬▒`.
    change i = j
    rw [ÔćÉ (QuotientAddGroup.out_eq' i), ÔćÉ (QuotientAddGroup.out_eq' j)]
    apply QuotientAddGroup.eq.mpr
    apply Ideal.mem_span_singleton'.mpr
    refine ÔčĘÔčĘ_, h01_intÔčę, ?_Ôčę
    apply (Subtype.coe_inj).mp
    push_cast
    rw [mul_comm ((╬▒ : v.adicCompletion F)Ôü╗┬╣) _, mul_assoc,
      inv_mul_cancelÔéÇ ((Subtype.coe_ne_coe).mpr h╬▒), mul_one]
    ring
  ┬Ě -- SurjOn: given `u Ôłł U1 r S`, pull `u` back via `r` to `w Ôłł GL2.TameLevel S`. The
    -- local surjOn at `v` provides `t : O_v/╬▒` such that the local ratio lies in
    -- `localTameLevel v = U1 v` (using `v Ôłł S`). We show that the preimage of the
    -- global ratio via `r` is in `GL2.TameLevel S` by checking at each place: at `v` it
    -- equals the local ratio, and at `w_place Ôëá v` it equals the projection of `w` at
    -- `w_place`, which is in the appropriate local level since `w Ôłł GL2.TameLevel S`.
    rintro _ ÔčĘ_, ÔčĘu, hu, _, rfl, rflÔčę, rflÔčę
    -- Extract the preimage `w Ôłł GL2.TameLevel S`.
    obtain ÔčĘw, hw_mem, hw_eqÔčę := Subgroup.mem_map.mp hu
    -- The projection of `w` at `v`.
    set g_loc : GL (Fin 2) (adicCompletion F v) :=
      FiniteAdeleRing.GL2.toAdicCompletion v w with hg_loc_def
    -- `g_loc Ôłł localTameLevel v` because `v Ôłł S` and `w Ôłł GL2.TameLevel S`.
    have hg_loc_tame : g_loc Ôłł GL2.localTameLevel v := hw_mem.2 v hv
    -- Apply the local surjOn.
    have hlocal_target :
        QuotientGroup.mk (g_loc * Local.GL2.diag ╬▒ h╬▒) Ôłł Local.U1diagU1 v ╬▒ h╬▒ :=
      ÔčĘ_, Set.mul_mem_mul hg_loc_tame rfl, rflÔčę
    obtain ÔčĘt, _, htÔčę :=
      Local.surjOn_unipotent_mul_diagU1_U1diagU1 ╬▒ h╬▒ hlocal_target
    -- The local ratio lies in `Local.U1 v = localTameLevel v`.
    have hlocal_ratio :
        (Local.GL2.unipotent_mul_diag ╬▒ h╬▒
            (Quotient.out t : adicCompletionIntegers F v))Ôü╗┬╣ *
          (g_loc * Local.GL2.diag ╬▒ h╬▒) Ôłł Local.U1 v :=
      QuotientGroup.eq.mp ht
    refine ÔčĘunipotent_mul_diag r ╬▒ h╬▒ t, ÔčĘt, trivial, rflÔčę, ?_Ôčę
    -- It suffices to show that the ratio is in `U1 r S`.
    apply QuotientGroup.eq.mpr
    refine Subgroup.mem_map.mpr ?_
    -- Build the global witness: the unique preimage `W Ôłł GLÔéé(­ŁöŞ)` of the ratio under `r`.
    set W : GL (Fin 2) (FiniteAdeleRing (­Łô× F) F) :=
      (FiniteAdeleRing.GL2.restrictedProduct.symm
        (RestrictedProduct.mulSingle _ v
          (Local.GL2.unipotent_mul_diag ╬▒ h╬▒
            (Quotient.out t : adicCompletionIntegers F v))))Ôü╗┬╣ *
      (w * FiniteAdeleRing.GL2.restrictedProduct.symm
        (RestrictedProduct.mulSingle _ v (Local.GL2.diag ╬▒ h╬▒))) with hW_def
    refine ÔčĘW, ?_, ?_Ôčę
    ┬Ě -- Show `W Ôłł GL2.TameLevel S`.
      refine ÔčĘfun w_place => ?_, fun w_place hwS => ?_Ôčę
      ┬Ě by_cases hwv : w_place = v
        ┬Ě subst hwv
          rw [hW_def]
          simp only [map_mul, map_inv]
          rw [FiniteAdeleRing.GL2.toAdicCompletion_restrictedProduct_symm_mulSingle_same w_place _,
            FiniteAdeleRing.GL2.toAdicCompletion_restrictedProduct_symm_mulSingle_same w_place _]
          exact hlocal_ratio.1
        ┬Ě rw [hW_def]
          simp only [map_mul, map_inv]
          rw [FiniteAdeleRing.GL2.toAdicCompletion_restrictedProduct_symm_mulSingle_ne hwv _,
            FiniteAdeleRing.GL2.toAdicCompletion_restrictedProduct_symm_mulSingle_ne hwv _]
          simp only [inv_one, one_mul, mul_one]
          exact hw_mem.1 w_place
      ┬Ě by_cases hwv : w_place = v
        ┬Ě subst hwv
          rw [hW_def]
          simp only [map_mul, map_inv]
          rw [FiniteAdeleRing.GL2.toAdicCompletion_restrictedProduct_symm_mulSingle_same w_place _,
            FiniteAdeleRing.GL2.toAdicCompletion_restrictedProduct_symm_mulSingle_same w_place _]
          exact hlocal_ratio
        ┬Ě rw [hW_def]
