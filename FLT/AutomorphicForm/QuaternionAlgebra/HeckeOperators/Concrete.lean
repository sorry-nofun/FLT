    (h : tÔéü - tÔéé Ôłł Ideal.span ({╬│} : Set (v.adicCompletionIntegers F)))
    (a : WeightTwoAutomorphicFormOfLevel (U1 r S) R) :
    unipotent_mul_diag_lift r ╬│ h╬│ tÔéü ÔÇó a.1 =
      unipotent_mul_diag_lift r ╬│ h╬│ tÔéé ÔÇó a.1 := by
  -- Strategy: write `lift tÔéü = lift tÔéé * u''` where `u'' = (lift tÔéé)Ôü╗┬╣ * lift tÔéü Ôłł U1 r S`.
  -- Then `lift tÔéü ÔÇó a = lift tÔéé ÔÇó (u'' ÔÇó a) = lift tÔéé ÔÇó a` using `a.2` on `u''`.
